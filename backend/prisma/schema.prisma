datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  name      String
  role      String   // 'PHYSICIAN', 'NURSE', 'SPECIALIST'
  specialty String?  // e.g., 'Pulmonology', 'Critical Care', 'Nephrology'
  createdAt DateTime @default(now())
}

model Patient {
  id            String          @id @default(uuid())
  mrn           String          @unique
  name          String
  age           Int
  gender        String
  comorbidities String          // Comma-separated or simple text of comorbidities
  admissionDate DateTime        @default(now())
  dischargeDate DateTime?
  status        String          // 'ICU', 'WARD', 'DISCHARGED', 'CONFIRM_STATUS'
  bed           String?
  events        ClinicalEvent[]
  narratives    Narrative[]
  createdAt     DateTime        @default(now())
}

model Bed {
  bedNumber  String  @id
  department String  // 'ICU', 'WARD'
  patientId  String? @unique
}

model ClinicalEvent {
  id             String   @id @default(uuid())
  patientId      String
  timestamp      DateTime
  eventType      String   // 'DIAGNOSIS', 'MEDICATION', 'PROCEDURE', 'INVESTIGATION', 'CONSULTATION', 'NOTE'
  sourceModality String   // 'TEXT', 'VOICE', 'DOCUMENT', 'IMAGE'
  eventData      String   // JSON string containing detailed payload
  provenance     String   // "Progress Note Day 3", "ASR Transcript", "Lab Report Page 1"
  authorId       String
  authorName     String
  authorRole     String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model Narrative {
  id                   String   @id @default(uuid())
  patientId            String   @unique
  courseInHospital     String   // Current compiled CoH text
  medicationJourney    String   // Ongoing medications text
  investigationJourney String   // Key lab trends text
  procedureJourney     String   // List of procedures text
  lastUpdated          DateTime @updatedAt
  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  userRole  String
  action    String   // 'CREATE_EVENT', 'UPDATE_EVENT', 'DELETE_EVENT', 'APPROVE_SUMMARY', 'REGENERATE_SUMMARY', 'LOGIN'
  timestamp DateTime @default(now())
  details   String   // Textual description or JSON of the change
}
